@page
@model elite_dangerous_colonise.Pages.LicencesModel
@{
    ViewData["Title"] = "Licences Page";
	ViewData["Description"] = "This page contains information about the licences used by ED Colonise.";
	ViewData["url"] = "https://edcolonise.net/Licences";
}
@section Scripts {
	<script src="~/js/licences.js" asp-append-version="true"></script>
}

<section class="mt-3 mb-3 rounded-md bg-[#F0F0F0] p-5">
	<div class="h-screen overflow-auto">
		<h1 class="pt-3 pb-3 text-xl">Third Party Package Licences</h1>
		<table id="packageLicences" class="border-1 w-full border-collapse border-[#0F0F0F]">
			<thead>
				<tr class="border-b-2 text-left">
					<th class="border-r-1 p-2">Package ID</th>
					<th class="border-r-1 p-2">Version</th>
					<th class="border-r-1 p-2">Package URL</th>
					<th class="border-r-1 p-2">Authors</th>
					<th class="border-r-1 p-2">License</th>
					<th class="border-r-1 p-2">Licence URL</th>
				</tr>
			</thead>
			<tbody></tbody>
		</table>
	</div>
	<div class="mt-5 overflow-auto">
		<h1 class="pt-3 pb-3 text-xl">Third Party CSS Licences</h1>
		<table id="packageLicences" class="border-1 w-full border-collapse border-[#0F0F0F]">
			<thead>
				<tr class="border-b-2 text-left">
					<th class="border-r-1 p-2">Library</th>
					<th class="border-r-1 p-2">Version</th>
					<th class="border-r-1 p-2">Library URL</th>
					<th class="border-r-1 p-2">Authors</th>
					<th class="border-r-1 p-2">License</th>
					<th class="border-r-1 p-2">Licence URL</th>
				</tr>
			</thead>
			<tbody>
				<tr class="bg-gray-300">
					<td class="border-r-1 p-2">TailwindCSS</td>
					<td class="border-r-1 p-2">4.1.3</td>
					<td class="border-r-1 p-2"><a href="https://tailwindcss.com/" target="_blank" class="text-blue-800 underline">https://tailwindcss.com/</a></td>
					<td class="border-r-1 p-2">Tailwind Labs</td>
					<td class="border-r-1 p-2">MIT</td>
					<td class="border-r-1 p-2"><a href="https://github.com/tailwindlabs/tailwindcss/blob/main/LICENSE" target="_blank" class="text-blue-800 underline">https://github.com/tailwindlabs/tailwindcss/blob/main/LICENSE</a></td>
				</tr>
				<tr>
					<td class="border-r-1 p-2">Flowbite</td>
					<td class="border-r-1 p-2">3.1.2</td>
					<td class="border-r-1 p-2"><a href="https://flowbite.com/" target="_blank" class="text-blue-800 underline">https://flowbite.com/</a></td>
					<td class="border-r-1 p-2">Themesberg</td>
					<td class="border-r-1 p-2">MIT</td>
					<td class="border-r-1 p-2"><a href="https://flowbite.com/docs/getting-started/license/" target="_blank" class="text-blue-800 underline">https://flowbite.com/docs/getting-started/license/</a></td>
				</tr>
				<tr class="bg-gray-300">
					<td class="border-r-1 p-2">Material Tailwind</td>
					<td class="border-r-1 p-2">3.0.0</td>
					<td class="border-r-1 p-2"><a href="https://www.material-tailwind.com/" target="_blank" class="text-blue-800 underline">https://www.material-tailwind.com/</a></td>
					<td class="border-r-1 p-2">Creative Tim</td>
					<td class="border-r-1 p-2">MIT</td>
					<td class="border-r-1 p-2"><a href="https://www.material-tailwind.com/docs/react/license" target="_blank" class="text-blue-800 underline">https://www.material-tailwind.com/docs/react/license</a></td>
				</tr>
			</tbody>
		</table>
	</div>
</section>
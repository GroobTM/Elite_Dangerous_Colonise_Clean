                <div id="black_holes_tooltip" role="tooltip" class="tooltip invisible absolute z-10 inline-block rounded-lg bg-[#0F0F0F] px-3 py-2 text-sm text-[#F0F0F0] opacity-0 shadow-xs transition-opacity duration-200">
                    Colony Influence: High Tech and Tourism
                </div>
            </div>
            <div class="mr-2 ml-2 flex min-h-13 flex-col justify-around">
                <div class="relative -top-2 w-full">
                    <span class="absolute left-1">Neutron Stars</span>
                    <div class="absolute right-1">
                        <svg data-tooltip-target="neutron_stars_tooltip" class="absolute right-20 h-6 w-6" version="1.1" id="Layer_1" x="0px" y="0px" width="924" height="924" viewBox="0 0 924 924" enable-background="new 0 0 924 924" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:svg="http://www.w3.org/2000/svg"><defs id="defs3" />

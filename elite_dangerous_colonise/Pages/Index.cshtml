@page
@model IndexModel
@{
    ViewData["Title"] = "Home Page";
    ViewData["Description"] = "ED Colonise is a colonisation helper for the game Elite Dangerous.";
    ViewData["url"] = "https://edcolonise.net/";
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/preline@3.2.3/dist/preline.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@preline/range-slider@3.2.3/index.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/nouislider@15.8.1/dist/nouislider.min.js"></script>
    <script src="~/js/index.js" asp-append-version="true"></script>
}

<aside class="mt-3 w-full rounded-md bg-[#F0F0F0]">
    <p id="update_countdown" class="text-center text-xl leading-15 text-[#0F0F0F]">Time Until Next Update: 0h 0m 0s</p>
</aside>
<section class="mt-3 w-full rounded-md bg-[#F0F0F0] p-3">
    <form id="systems_search" method="GET">
        <div class="flex flex-col justify-between gap-3 lg:flex-row lg:gap-5">
            <div id="colonised_system_search" class="relative flex-1">
                <div class="relative">
                    <input asp-for="ColonisedSystem" type="text" role="combobox" id="colonised_system" class="peer block w-full appearance-none rounded-lg border-1 border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:border-[#F07B05] focus:ring-0 focus:outline-none" placeholder=" " maxlength="75" data-hs-combo-box-input="" />
                    <label for="colonised_system" class="absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 transform cursor-text rounded-3xl bg-white px-2 text-[#0F0F0F] duration-200 peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:scale-100 peer-focus:top-0 peer-focus:-translate-y-4 peer-focus:scale-85 peer-focus:p-1 peer-focus:px-2 peer-focus:shadow-sm rtl:peer-focus:left-auto rtl:peer-focus:translate-x-1/4">Colonised System (Optional)</label>
                    <label for="colonised_system" id="clear_button" class="absolute top-1 right-2 z-10 cursor-pointer text-3xl">&times;</label>
                </div>
                <div class="absolute z-50 !mt-0 max-h-55 w-full overflow-y-auto rounded-lg border-1 border-[#BCBCBC] bg-white shadow-lg" style="display: none;" role="listbox" data-hs-combo-box-output=""></div>
            </div>
            <div class="relative flex-1">
                <select asp-for="SortOrder" id="sortOrder" class="block w-full cursor-pointer appearance-none rounded-lg border-1 border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:border-[#F07B05] focus:ring-0 focus:outline-none">
                    <option value="SystemValue">System Value</option>
                    <option value="MostWalkables">Most Walkable Bodies</option>
                    <option value="MostHotspots">Most Hotspots</option>
                    <option value="bodyValue">Notable Body Value</option>
                    <option value="DistanceToSol">Distance to Sol</option>
                    <option value="DistanceToTrailblazer">Distance to Trailblazer Megaship</option>
                </select>
                <label for="sortOrder" class="pointer-events-none absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 rounded-3xl bg-white px-2 text-[#0F0F0F]">Sort Order</label>
                <svg class="pointer-events-none absolute top-5 right-3 z-10 h-4 w-4 shrink-0 rotate-180 text-[#0F0F0F]" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"></path>
                </svg>
            </div>
        </div>
        <div class="relative mt-3 flex flex-col-reverse gap-2 lg:flex-row">
            <div class="grid w-full lg:w-45">
                <input type="button" id="more_options_button" class="col-3 col-start-1 row-start-1 row-end-2 block w-full cursor-pointer rounded-lg border-1 border-[#0F0F0F] bg-[#0F0F0F] px-2.5 pt-3 pb-3 text-left shadow-sm hover:border-[#F07B05] hover:bg-[#F07B05]" value="" />
                <label for="search" class="pointer-events-none relative z-10 col-3 col-start-1 row-start-1 row-end-2 flex w-full items-center justify-center gap-5 text-[#F0F0F0]">
                    <span>More Options</span>
                    <svg id="more_options_icon" class="absolute top-5 right-10 h-3 w-3 shrink-0 rotate-180 transition-transform duration-200 lg:relative lg:top-0.5 lg:right-auto" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5" />
                    </svg>
                </label>
            </div>
            <div class="flex flex-1 items-center justify-end gap-5">
                <div class="flex items-center">
                    <input asp-for="IncludeClaimed" type="checkbox" id="include_claimed" value="include" class="h-6 w-6 cursor-pointer accent-[#0F0F0F] shadow-sm" />
                    <label for="include_claimed" class="ml-2 cursor-pointer text-sm text-[#0F0F0F] sm:text-base">Include Claimed Systems</label>
                </div>
                <div class="grid w-45">
                    <input type="submit" id="search" class="col-3 col-start-1 row-start-1 row-end-2 block w-full cursor-pointer rounded-lg border-1 border-[#0F0F0F] bg-[#0F0F0F] px-2.5 pt-3 pb-3 text-left shadow-sm" value="" />
                    <label for="search" class="pointer-events-none z-10 col-3 col-start-1 row-start-1 row-end-2 flex w-full items-center justify-center gap-5">
                        <span class="text-[#F0F0F0]">Search</span>
                        <img src="~/images/courier.svg" class="z-10 h-8 sm:h-10" />
                    </label>
                </div>
            </div>
        </div>
        <div id="more_options" class="mt-3 hidden grid-cols-1 gap-y-5 lg:grid-cols-2 lg:gap-x-5">
            <div id="faction_search" class="relative flex-1">
                <div class="relative">
                    <input asp-for="Faction" type="text" role="combobox" id="faction" class="peer block w-full appearance-none rounded-lg border-1 border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:border-[#F07B05] focus:ring-0 focus:outline-none" placeholder=" " maxlength="75" data-hs-combo-box-input="" />
                    <label for="faction" class="absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 transform cursor-text rounded-3xl bg-white px-2 text-[#0F0F0F] duration-200 peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:scale-100 peer-focus:top-0 peer-focus:-translate-y-4 peer-focus:scale-85 peer-focus:p-1 peer-focus:px-2 peer-focus:shadow-sm rtl:peer-focus:left-auto rtl:peer-focus:translate-x-1/4">Faction (Optional)</label>
                    <label for="faction" id="clear_button" class="absolute top-1 right-2 z-10 cursor-pointer text-3xl">&times;</label>
                </div>
                <div class="absolute z-50 !mt-0 max-h-55 w-full overflow-y-auto rounded-lg border-1 border-[#BCBCBC] bg-white shadow-lg" style="display: none;" role="listbox" data-hs-combo-box-output=""></div>
            </div>

            <div class="mr-2 ml-2 flex min-h-13 flex-col justify-around">
                <div class="relative -top-2 w-full">
                    <span class="absolute left-1">Max Distance From Sol</span>
                    <span id="distance_from_sol_value" class="absolute right-1">@Model.MaxValues.DistanceToSol ly</span>
                </div>
                <div id="distance_from_sol_slider" class="--prevent-on-load-init" data-hs-range-slider='{
                    "start": @Model.MaxValues.DistanceToSol,
                    "range": {
                        "min": 0,
                        "max": @Model.MaxValues.DistanceToSol
                    },
                    "step": 1,
                    "connect": "lower",
                    "cssClasses": {
                        "target": "relative h-2.5 rounded-full bg-white border-1 border-[#0F0F0F]",
                        "base": "size-full relative z-1",
                        "origin": "absolute top-0 end-0 size-full origin-[0_0] rounded-full",
                        "handle": "absolute top-1/2 end-0 size-5 bg-white border-3 border-[#0F0F0F] rounded-full cursor-pointer translate-x-2/4 -translate-y-2/4",
                        "connects": "relative z-0 size-full rounded-full overflow-hidden",
                        "connect": "absolute top-0 end-0 z-1 size-full bg-[#F07B05] origin-[0_0]",
                        "touchArea": "absolute -inset-1"
                    }
                }'></div>
            </div>
            <div class="mr-2 ml-2 flex min-h-13 flex-col justify-around">
                <div class="relative -top-2 w-full">
                    <span class="absolute left-1">Landable Bodies</span>
                    <span id="landable_bodies_value" class="absolute right-1">0 - @Model.MaxValues.LandableCount</span>
                </div>
                <div id="landable_bodies_slider" class="--prevent-on-load-init" data-hs-range-slider='{
                    "start": [0, @Model.MaxValues.LandableCount],
                    "range": {
                        "min": 0,
                        "max": @Model.MaxValues.LandableCount
                    },
                    "step": 1,
                    "connect": true,
                    "cssClasses": {
                        "target": "relative h-2.5 rounded-full bg-white border-1 border-[#0F0F0F]",
                        "base": "size-full relative z-1",
                        "origin": "absolute top-0 end-0 size-full origin-[0_0] rounded-full",
                        "handle": "absolute top-1/2 end-0 size-5 bg-white border-3 border-[#0F0F0F] rounded-full cursor-pointer translate-x-2/4 -translate-y-2/4",
                        "connects": "relative z-0 size-full rounded-full overflow-hidden",
                        "connect": "absolute top-0 end-0 z-1 size-full bg-[#F07B05] origin-[0_0]",
                        "touchArea": "absolute -inset-1"
                    }
                }'></div>
            </div>
            <div class="mr-2 ml-2 flex min-h-13 flex-col justify-around">

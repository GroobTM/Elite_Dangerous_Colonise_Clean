@page
@model IndexModel
@{
    ViewData["Title"] = "Home Page";
    ViewData["Description"] = "ED Colonise is a colonisation helper for the game Elite Dangerous.";
    ViewData["url"] = "https://edcolonise.net/";
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
    <script src="~/js/index.js" asp-append-version="true"></script>
    
}

<aside class="mt-3 w-full rounded-md bg-[#F0F0F0]">
    <p id="update_countdown" class="text-center text-xl leading-15 text-[#0F0F0F]">Time Until Next Update: 0h 0m 0s</p>
</aside>
<section class="mt-3 w-full rounded-md bg-[#F0F0F0] p-3">
    <form id="systems_search" method="GET">
        <div class="flex flex-col justify-between gap-3 lg:gap-15 lg:flex-row">
            <div class="relative flex-1">
                <input asp-for="ColonisedSystem" type="text" id="colonised_system" class="border-1 peer block w-full appearance-none rounded-lg border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:outline-none focus:ring-0 focus:border-[#F07B05]" placeholder=" " maxlength="75"/>
                <label for="colonised_system" class="absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 transform cursor-text rounded-3xl bg-white px-2 text-[#0F0F0F] duration-200 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:px-2 peer-focus:p-1 peer-focus:shadow-sm peer-focus:top-0 peer-focus:scale-85 peer-focus:-translate-y-4 rtl:peer-focus:translate-x-1/4 rtl:peer-focus:left-auto">Colonised System (Optional)</label>
                <label for="colonised_system" id="clear_button" class="absolute top-1 right-2 z-10 cursor-pointer text-3xl">&times;</label>
            </div>
            <div class="relative flex-1">
                <input asp-for="Faction" type="text" id="faction" class="border-1 peer block w-full appearance-none rounded-lg border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:outline-none focus:ring-0 focus:border-[#F07B05]" placeholder=" " maxlength="75" />
                <label for="faction" class="absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 transform cursor-text rounded-3xl bg-white px-2 text-[#0F0F0F] duration-200 peer-placeholder-shown:scale-100 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:p-1 peer-focus:shadow-sm peer-focus:px-2 peer-focus:top-0 peer-focus:scale-85 peer-focus:-translate-y-4 rtl:peer-focus:translate-x-1/4 rtl:peer-focus:left-auto">Faction (Optional)</label>
                <label for="faction" id="clear_button" class="absolute top-1 right-2 z-10 cursor-pointer text-3xl">&times;</label>
            </div>
            <div class="relative flex-1">
                <select asp-for="SortOrder" id="sortOrder" class="border-1 block w-full cursor-pointer appearance-none rounded-lg border-[#0F0F0F] bg-white px-2.5 pt-4 pb-2.5 pl-4 text-[#0F0F0F] shadow-sm focus:outline-none focus:ring-0 focus:border-[#F07B05]">
                    <option value="totalValue">Combined Value</option>
                    <option value="landableBodies">Most Landable Bodies</option>
                    <option value="hotspots">Most Hotspots</option>
                    <option value="bodyValue">Notable Body Value</option>
                    <option value="solDistance">Distance to Sol</option>
                    <option value="trailblazerDistance">Distance to Trailblazer Megaship</option>
                </select>
                <label for="sortOrder" class="pointer-events-none absolute start-2 top-2 z-10 origin-[0] -translate-y-4 scale-85 rounded-3xl bg-white px-2 text-[#0F0F0F]">Sort Order</label>
                <svg class="pointer-events-none absolute top-5 right-3 z-10 h-4 w-4 shrink-0 rotate-180 text-[#0F0F0F]" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"></path>
                </svg>
            </div>
        </div>
        <div class="relative mt-3 flex flex-1 items-center justify-end gap-5">
            <div class="flex items-center">
                <input asp-for="IncludeClaimed" type="checkbox" id="include_claimed" value="include" class="h-6 w-6 cursor-pointer accent-[#0F0F0F] shadow-sm" />
                <label for="include_claimed" class="ml-2 cursor-pointer text-sm text-[#0F0F0F] sm:text-base">Include Claimed Systems</label>
            </div>
            <div class="grid w-45">
                <input type="submit" id="search" class="border-1 col-3 col-start-1 row-start-1 row-end-2 block w-full cursor-pointer rounded-lg border-[#0F0F0F] bg-[#0F0F0F] px-2.5 pt-3 pb-3 text-left shadow-sm" value="" />
                <label for="search" class="pointer-events-none z-10 col-3 col-start-1 row-start-1 row-end-2 flex w-full items-center justify-center gap-5">
                    <span class="text-[#F0F0F0]">Search</span>
                    <img src="~/images/courier.svg" class="z-10 h-8 sm:h-10" />
                </label>
            </div>
        </div>
    </form>
</section>
<section class="relative mt-3 mb-3 w-full rounded-md bg-[#F0F0F0] p-3">
    <div class="flex flex-col gap-3 md:justify-between md:gap-0 md:flex-row">
        <h1 class="text-center text-xl text-[#0F0F0F] md:text-left">Colonisation Candidates</h1>
        <div class="flex flex-col gap-4 md:flex-row">
            <div class="flex items-center justify-center gap-2">
                <label id="results_per_page_lbl" class="text-sm text-[#0F0F0F]">Results per page</label>
                <select id="results_per_page" class="min-h-full cursor-pointer rounded-md border border-[#0F0F0F] bg-white p-2.5 text-center text-sm text-[#0F0F0F] shadow-sm transition-all hover:shadow-lg hover:text-[#F0F0F0] hover:bg-slate-800 hover:border-[#0F0F0F] focus:text-[#F0F0F0] focus:bg-[#0F0F0F] focus:border-[#0F0F0F] active:border-[#0F0F0F] active:text-[#F0F0F0] active:bg-[#0F0F0F] disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="flex justify-center gap-2">
                <button id="previous_page" class="cursor-pointer rounded-md border border-[#0F0F0F] bg-white p-2.5 text-center text-sm text-[#0F0F0F] shadow-sm transition-all hover:shadow-lg hover:text-[#F0F0F0] hover:bg-slate-800 hover:border-[#0F0F0F] focus:text-[#F0F0F0] focus:bg-[#0F0F0F] focus:border-[#0F0F0F] active:border-[#0F0F0F] active:text-[#F0F0F0] active:bg-[#0F0F0F] disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none" type="button">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                        <path fill-rule="evenodd" d="M11.03 3.97a.75.75 0 0 1 0 1.06l-6.22 6.22H21a.75.75 0 0 1 0 1.5H4.81l6.22 6.22a.75.75 0 1 1-1.06 1.06l-7.5-7.5a.75.75 0 0 1 0-1.06l7.5-7.5a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                    </svg>
                </button>
                <div>
                    <button id="select_page_btn" class="h-11 w-36 cursor-pointer rounded-md border border-[#0F0F0F] bg-white p-2.5 text-center text-sm text-[#0F0F0F] shadow-sm transition-all hover:shadow-lg hover:text-[#F0F0F0] hover:bg-[#0F0F0F] hover:border-[#0F0F0F] focus:text-[#F0F0F0] focus:bg-[#0F0F0F] focus:border-[#0F0F0F] active:border-[#0F0F0F] active:text-[#F0F0F0] active:bg-[#0F0F0F] disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none" type="button">
                        Page <strong id="current_page">0</strong>&nbsp;of&nbsp;<strong id="max_pages">0</strong>
                    </button>
                    <form id="select_page_form" class="hidden" autocomplete="off">
                        <input type="number" class="h-11 w-36 cursor-pointer rounded-md border border-[#0F0F0F] bg-white p-2.5 text-center text-sm text-[#0F0F0F] shadow-sm transition-all hover:shadow-lg hover:text-[#F0F0F0] hover:bg-[#0F0F0F] hover:border-[#0F0F0F] focus:outline-none focus:ring-0 focus:border-[#F07B05] active:border-[#0F0F0F] active:text-[#F0F0F0] active:bg-[#0F0F0F] disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none" min="1" placeholder="Jump to Page" required />
                        <input type="submit" class="hidden" />
                    </form>
                </div>
                <button id="next_page" class="cursor-pointer rounded-md border border-[#0F0F0F] bg-white p-2.5 text-center text-sm text-[#0F0F0F] shadow-sm transition-all hover:shadow-lg hover:text-[#F0F0F0] hover:bg-[#0F0F0F] hover:border-[#0F0F0F] focus:text-[#F0F0F0] focus:bg-[#0F0F0F] focus:border-[#0F0F0F] active:border-[#0F0F0F] active:text-[#F0F0F0] active:bg-[#0F0F0F] disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none" type="button">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                        <path fill-rule="evenodd" d="M12.97 3.97a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 0 1 0 1.06l-7.5 7.5a.75.75 0 1 1-1.06-1.06l6.22-6.22H3a.75.75 0 0 1 0-1.5h16.19l-6.22-6.22a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
    <div id="results" data-accordion="open" class="mt-3">
        <div role="status" class="w-full animate-pulse space-y-3 rounded-t-lg border border-[#0F0F0F] bg-white shadow-sm">
            <div class="flex items-center justify-between border-b-1 border-[#0F0F0F] p-4 pt-6">
                <div class="mb-2.5 h-2.5 w-24 rounded-full bg-gray-300"></div>
                <div class="h-2.5 w-12 rounded-full bg-gray-300"></div>
            </div>
            <div class="flex items-center justify-between border-b-1 border-[#0F0F0F] p-4">
                <div class="mb-2.5 h-2.5 w-24 rounded-full bg-gray-300"></div>
                <div class="h-2.5 w-12 rounded-full bg-gray-300"></div>
            </div>
            <div class="flex items-center justify-between border-b-1 border-[#0F0F0F] p-4">
                <div class="mb-2.5 h-2.5 w-24 rounded-full bg-gray-300"></div>
                <div class="h-2.5 w-12 rounded-full bg-gray-300"></div>
            </div>
            <div class="flex items-center justify-between border-b-1 border-[#] p-4">
                <div class="mb-2.5 h-2.5 w-24 rounded-full bg-gray-300"></div>
                <div class="h-2.5 w-12 rounded-full bg-gray-300"></div>
            </div>
            <div class="flex items-center justify-between p-4">
                <div class="mb-2.5 h-2.5 w-24 rounded-full bg-gray-300"></div>
                <div class="h-2.5 w-12 rounded-full bg-gray-300"></div>
            </div>
        </div>
    </div>
    <div id="loading" class="absolute top-0 left-0 z-20 hidden h-full w-full items-center justify-center rounded-md border bg-[#F0F0F0BF]">
        <div role="status">
            <svg aria-hidden="true" class="h-12 w-12 animate-spin fill-[#F07B05] text-gray-400" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor" /><path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill" /></svg>
            <span class="sr-only">Loading...</span>
        </div>
    </div>
</section>


                        "connects": "relative z-0 size-full rounded-full overflow-hidden",
                        "connect": "absolute top-0 end-0 z-1 size-full bg-[#F07B05] origin-[0_0]",
                        "touchArea": "absolute -inset-1"
                    }
                }'></div>
            </div>
            <span class="m-0 h-1 rounded-full bg-[#DFDFDF] lg:col-start-1 lg:col-end-3"></span>
            <div class="mr-2 ml-2 flex min-h-13 flex-col justify-around">
                <div class="relative -top-2 w-full">
                    <span class="absolute left-1">Black Holes</span>
                    <div class="absolute right-1">
                        <svg data-tooltip-target="black_holes_tooltip" class="absolute right-20 h-6 w-6" version="1.1" id="Layer_1" x="0px" y="0px" width="924" height="924" viewBox="0 0 924 924" enable-background="new 0 0 924 924" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:svg="http://www.w3.org/2000/svg"><defs id="defs3" />
	                        <g id="g1">
		                        <path class="fill-[#00FFFF]" d="M 458.18182,917.9913 8.1454545,468.46402 46.836364,883.88221 Z" id="path7" />
		                        <path class="fill-[#6600E5]" d="M 458.84246,917.9913 908.87883,468.46402 870.18792,883.88221 Z" id="path8" />
		                        <path class="fill-[#00FFFF]" d="M 458.18182,12.727273 8.1454545,462.25455 46.836364,46.836364 Z" id="path9" />
